---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About | Portfolio" description="About me.">
  <section class="md:mx-28 mx-6 my-0 py-6 pt-[72px] max-w-2xl">
    <p class="text-[hsl(var(--foreground))] leading-relaxed">
      A short bio or about text goes here. You can edit this in
      <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded">src/pages/about.astro</code>.
    </p>
  </section>
</BaseLayout>
