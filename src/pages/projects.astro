---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---
<BaseLayout title="Projects | Portfolio" description="Project list and case studies.">
  <section class="md:mx-28 mx-6 my-0 py-6 pt-[72px] max-w-3xl">
    <h1 class="text-3xl font-semibold text-[hsl(var(--foreground))] mb-4">Projects</h1>
    <p class="text-[hsl(var(--foreground))] leading-relaxed mb-8">
      A selected list of projects with context on outcomes, role, and implementation details.
    </p>

    <div class="space-y-7">
      {
        projects.map((project) => (
          <article class="border-b border-[hsl(var(--foreground))]/10 pb-6">
            <h2 class="text-xl font-medium text-[hsl(var(--foreground))] mb-2">{project.title}</h2>
            <p class="text-[hsl(var(--foreground))] leading-relaxed mb-3">
              {project.outcome ?? 'Project outcome summary coming soon.'}
            </p>
            <p class="text-[hsl(var(--foreground))] leading-relaxed mb-1">
              <strong>Role:</strong> {project.role ?? 'Role details coming soon.'}
            </p>
            <div class="flex gap-4 text-sm mt-3">
              <a class="underline underline-offset-4 hover:no-underline" href={project.liveUrl ?? project.slug} target="_blank" rel="noopener">
                Link
              </a>
            </div>

            {
              project.title === 'Graphics Projects' && (
                <div class="mt-6 space-y-6">
                  <section>
                    <h3 class="text-lg font-medium mb-2">Project 1 - Video Submission</h3>
                    <p class="text-[hsl(var(--foreground))] leading-relaxed mb-2">
                      Add your video to <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded">public/videos/graphics-project-1.mp4</code>
                      and it will render here.
                    </p>
                    <video class="w-full rounded border border-[hsl(var(--foreground))]/10" controls preload="metadata">
                      <source src="/videos/graphics-project-1.mp4" type="video/mp4" />
                      Your browser does not support embedded videos.
                    </video>
                  </section>

                  <section>
                    <h3 class="text-lg font-medium mb-2">Project 2 - Image Gallery</h3>
                    <p class="text-[hsl(var(--foreground))] leading-relaxed mb-3">
                      Place your four images in <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded">public/images/graphics/</code> using
                      these filenames:
                      <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded ml-1">project2-1.png</code>,
                      <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded ml-1">project2-2.png</code>,
                      <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded ml-1">project2-3.png</code>,
                      <code class="text-sm bg-black/5 dark:bg-white/10 px-1 rounded ml-1">project2-4.png</code>.
                    </p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      <img src="/images/graphics/project2-1.png" alt="Graphics project 2 image 1" class="w-full rounded border border-[hsl(var(--foreground))]/10" loading="lazy" />
                      <img src="/images/graphics/project2-2.png" alt="Graphics project 2 image 2" class="w-full rounded border border-[hsl(var(--foreground))]/10" loading="lazy" />
                      <img src="/images/graphics/project2-3.png" alt="Graphics project 2 image 3" class="w-full rounded border border-[hsl(var(--foreground))]/10" loading="lazy" />
                      <img src="/images/graphics/project2-4.png" alt="Graphics project 2 image 4" class="w-full rounded border border-[hsl(var(--foreground))]/10" loading="lazy" />
                    </div>
                  </section>

                  <section>
                    <h3 class="text-lg font-medium mb-2">Project 3 - Cornell CS4620 Standout</h3>
                    <p class="text-[hsl(var(--foreground))] leading-relaxed">
                      Featured on the CS4620 final project standouts page with Chris Um:
                      <a
                        class="underline underline-offset-4 hover:no-underline ml-1"
                        href="https://www.cs.cornell.edu/courses/cs4620/2025fa/assignments/docs/assignments/FinalProject/standouts"
                        target="_blank"
                        rel="noopener"
                      >
                        View standout listing
                      </a>
                    </p>
                  </section>
                </div>
              )
            }
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
